/* Custom Defined Behaviors */
/ {
    behaviors {
        tog_lock_v1_TKZ: toggle_layer_lock_v1_TKZ {
            compatible = "zmk,behavior-toggle-layer";
            #binding-cells = <1>;
            display-name = "Locking Toggle Layer";
            toggle-mode = "flip";
            locking;
        };

        arrow_morph: arrow_morph {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&arrow_alt_morph>, <&arrow_shift_alt_morph>;
            mods = <(MOD_LSFT|MOD_RSFT)>;
        };

        arrow_alt_morph: arrow_alt_morph {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&arrow_plain_macro>, <&arrow_alt_macro>;
            mods = <(MOD_LALT|MOD_RALT)>;
        };

        arrow_shift_alt_morph: arrow_shift_alt_morph {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&arrow_shift_macro>, <&arrow_shift_alt_macro>;
            mods = <(MOD_LALT|MOD_RALT)>;
        };
    };
};

